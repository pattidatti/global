{
  "name": "geopolity-functions",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "mkdir -p data && cp ../public/geo/regions-meta.json data/regions-meta.json && tsc",
    "watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "test": "vitest run"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
